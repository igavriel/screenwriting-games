[align center]
# 🚀 זה לא היה בתדריך 🚀

## משימת חקר שגרתית. כוכב לא ממופה. אות לא מזוהה.

### הכול תועד. הכול נותח. הכול אמור להיות תחת שליטה.

ככה זה תמיד מתחיל.

כי אם יש משהו שאפשר לסמוך עליו -  
זה שתדריכים נכתבים על סמך מה שכבר קרה.

ובקצה המשימה הזו…

מה כבר יכול להשתבש, באמת?

[continue]
> [[מסעות חללית "החלוץ-7" ->1-Start]]


:: 1-Start {"position":"300,100","size":"100,100"}
crew1: ''
crew2: ''
hasFighter: false
hasDoctor: false
hasScientist: false
hasMechanic: false
visitedVillage: false
hits: 0
misses: 0
roll: 0
battleThreshold: 4
totalHits: 2
totalLife: 4
--
# 🚀 פרוטוקול נחיתה על כוכב

ספינת המחקר "**החלוץ-7**״ חוצה את החלל העמוק כמו מחט כסופה השוזרת את הכוכבים.

אני מפקד הספינה, רגוע תחת לחץ, חד מול הלא־נודע, ואחראי לכל הצוות שעל הסיפון.

במשך שבועות אנו עוקבים אחרי אותות חלשים מעולם שאינו מופיע באף מפה, בקצה המרחב הידוע. השידורים מקוטעים, מחזוריים, וללא ספק מלאכותיים.

יש קצינים שמשווים את המשימה הזו למסעות הגדולים של אגדות החלל - שילוב של דיפלומטיה, מדע וסכנה.

[after 2000ms]
אני עדיין לא בטוח אם זו מחמאה, או אזהרה.

הלילה, סוף סוף, כוכב מסתורי ממלא את המסך הראשי.
המרחק נסגר. הרגע הגיע.

[continue]
> [[המשך לתדריך 🧭->Planet Briefing]]


:: Cave-Battle Code [CODE] {"position":"1600,100","size":"100,100"}
[JavaScript]
const threshold = battleThreshold;

// map number to dice emoji
const diceEmojis = ['⚀', '⚁', '⚂', '⚃', '⚄', '⚅'];
const dice = diceEmojis[roll - 1];

// pick random crew member
const crew = [crew1, crew2];
const activeCrew = crew[Math.floor(Math.random() * crew.length)];

function getCrewLine(crew, isHit) {
  if (crew === "לוחם") {
    return isHit
      ? "⚔️ הלוחם מסתער ראשון - המכה פוגעת בעוצמה."
      : "⚔️ הלוחם נסוג חצי צעד - היצור תוקף.";
  }

  if (crew === "רופא") {
    return isHit
      ? "🩺 הרופא שומר על קור רוח - הפגיעה מדויקת."
      : "🩺 הרופא מזהיר - אבל אין זמן להגיב.";
  }

  if (crew === "מדען") {
    return isHit
      ? "🔬 המדען מכוון את הרגע - הפגיעה נכנסת בדיוק."
      : "🔬 המדען מזהה את הסכנה מאוחר מדי.";
  }

  if (crew === "מכונאי") {
    return isHit
      ? "🔧 המכונאי מזהה חולשה - המכה חודרת."
      : "🔧 המכונאי מנסה לאלתר - אבל זה לא מספיק.";
  }

  return "";
}

let isHit = false;
let reason = "";

// scientist bonus
if (!isHit && hasScientist && roll === threshold) {
  isHit = true;
  reason = "🔬 המדען מזהה דפוס - הפגיעה נרשמת ברגע המדויק.";
}

// mechanic bonus
else if (!isHit && hasMechanic && roll === threshold - 1) {
  isHit = true;
  reason = "🔧 המכונאי מנצל חוסר יציבות - נוצר פתח לפגיעה.";
}

// normal hit
else if (roll > threshold) {
  isHit = true;
  reason = getCrewLine(activeCrew, true);
}

// miss
else {
  misses++;
  reason = getCrewLine(activeCrew, false);
}

// apply hit
if (isHit) {
  hits++;
}

// line 1 - dice result
write(`## ${dice} (**${roll}**)`);

if (isHit) {
  write(`<span style="color:darkgreen;">**פגיעה!**</span>`);
} else {
  write(`<span style="color:red;">**החטאה!**</span>`);
}

// line 2 - who acted + explanation
write(`\n### `);
write(reason);

// tension warning
if (misses === totalLife - 1) {
  write("\n# ⚠️ עוד החטאה אחת - וזה נגמר.");
}
[continued]


:: Cave-Entrance {"position":"1100,400","size":"100,100"}
battleThreshold: hasFighter || visitedVillage ? 2 : 4
totalLife: hasDoctor ? 4 : 3
